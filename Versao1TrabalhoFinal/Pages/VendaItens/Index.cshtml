@page
@model Versao1TrabalhoFinal.Pages.VendaItens.IndexModel
@{
    ViewData["Title"] = "Itens de Venda";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Itens de venda</h2>
    <a asp-page="./Create" class="btn btn-primary">Novo Item</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Venda</th>
                    <th>Produto</th>
                    <th>Quantidade</th>
                    <th>Preço</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Itens)
                {
                    <tr>
                        <td>#@item.VendaId</td>
                        <td>@item.Produto?.Nome</td>
                        <td>@item.Quantidade</td>
                        <td>€ @item.Preco</td>
                        <td class="text-end">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@page
@model Versao1TrabalhoFinal.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="page-title">Dashboard</h1>

<div class="row g-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Clientes</div>
                    <div class="stat-value">@Model.TotalClientes</div>
                </div>
                <div class="stat-icon icon-blue">
                    <i class="bi bi-people-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Veículos</div>
                    <div class="stat-value">@Model.TotalVeiculos</div>
                </div>
                <div class="stat-icon icon-green">
                    <i class="bi bi-car-front-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Produtos</div>
                    <div class="stat-value">@Model.TotalProdutos</div>
                </div>
                <div class="stat-icon icon-yellow">
                    <i class="bi bi-box-seam-fill"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Serviços</div>
                    <div class="stat-value">@Model.TotalServicos</div>
                </div>
                <div class="stat-icon icon-red">
                    <i class="bi bi-tools"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
                    <div class="stat-label">Ordens abertas</div>
                    <div class="stat-value text-warning">@Model.OrdensAbertas</div>
                </div>
                <div class="stat-icon icon-yellow">
                    <i class="bi bi-clipboard-check-fill"></i>
                </div>
            </div>
        </div>
    </div>
</div>

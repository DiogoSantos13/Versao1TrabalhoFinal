@page
@model Versao1TrabalhoFinal.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Clientes</h2>
    <a asp-page="/Clientes/Create" class="btn btn-primary">Novo Cliente</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Telefone</th>
                        <th>Email</th>
                        <th>NIF</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cliente in Model.Clientes)
                    {
                        <tr>
                            <td>@cliente.Nome</td>
                            <td>@cliente.Telefone</td>
                            <td>@cliente.Email</td>
                            <td>@cliente.NIF</td>
                            <td class="text-end">
                                <a asp-page="/Clientes/Edit" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                <a asp-page="/Clientes/Delete" asp-route-id="@cliente.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

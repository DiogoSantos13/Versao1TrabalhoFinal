@page "{id:int}"
@model Versao1TrabalhoFinal.Pages.Clientes.EditModel
@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="mb-4">Editar cliente</h2>

                <form method="post">
                    <input type="hidden" asp-for="Cliente.Id" />
                    <input type="hidden" asp-for="Cliente.DataRegisto" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Cliente.Nome" class="form-label"></label>
                            <input asp-for="Cliente.Nome" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Cliente.Telefone" class="form-label"></label>
                            <input asp-for="Cliente.Telefone" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Cliente.Email" class="form-label"></label>
                        <input asp-for="Cliente.Email" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Cliente.NIF" class="form-label"></label>
                        <input asp-for="Cliente.NIF" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Cliente.Morada" class="form-label"></label>
                        <input asp-for="Cliente.Morada" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Cliente.ImagemUrl" class="form-label"></label>
                        <input asp-for="Cliente.ImagemUrl" class="form-control" />
                    </div>

                    <button class="btn btn-primary" type="submit">Guardar alterações</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>

@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Stand Premium</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header id="siteHeader" class="site-header">
        <div class="nav-left">
            <button type="button" class="nav-menu-trigger" aria-label="Abrir menu">
                <i class="fa-solid fa-bars"></i>
            </button>
        </div>

        <div class="nav-logo">
            <a asp-page="/Index">
                <img src="~/images/logotipo.png" alt="Logo Stand Premium" asp-append-version="true">
            </a>
        </div>

        <div class="nav-right">
            <a asp-page="/VeiculosStand/Index" class="nav-link-custom">
                <i class="fa-solid fa-car"></i>
                <span>Stand</span>
            </a>

            <a asp-page="/Servicos/Index" class="nav-link-custom">
                <i class="fa-solid fa-briefcase"></i>
                <span>Serviços</span>
            </a>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a asp-page="/Veiculos/Index" class="nav-link-custom">
                    <i class="fa-solid fa-car-side"></i>
                    <span>Minhas Viaturas</span>
                </a>
            }

            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Cliente"))
            {
                <a asp-page="/GestaoOrcamentos/Index" class="nav-link-custom nav-link-highlight">
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                    <span>Orçamentos</span>
                </a>
            }

            @if (User.Identity != null && User.Identity.IsAuthenticated && (User.IsInRole("Admin") || User.IsInRole("Colaborador")))
            {
                <a asp-page="/Clientes/Index" class="nav-link-custom">
                    <i class="fa-solid fa-users"></i>
                    <span>Clientes</span>
                </a>
            }

            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Cliente"))
            {
                <a asp-page="/Carrinho/Index" class="nav-link-custom">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Carrinho</span>
                </a>
            }

            <a asp-page="/Contactos" class="nav-link-custom">
                <i class="fa-solid fa-envelope"></i>
                <span>Contactos</span>
            </a>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <div class="nav-auth-group">
                    <span class="nav-user-name">@User.Identity.Name</span>

                    <form asp-area="Identity"
                          asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Page("/Index")"
                          method="post"
                          class="navbar-auth-form">
                        <button type="submit" class="navbar-auth-button" aria-label="Terminar sessão">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            <span>Sair</span>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login" class="nav-link-auth">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    <span>Iniciar Sessão</span>
                </a>
            }
        </div>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <a href="https://wa.me/351916632118" class="wp-float" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
        <i class="fa-brands fa-whatsapp"></i>
    </a>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        window.addEventListener('scroll', function () {
            const header = document.getElementById('siteHeader');
            if (!header) return;

            if (window.scrollY > 50) {
                header.classList.add('scrolled');
            } else {
                header.classList.remove('scrolled');
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

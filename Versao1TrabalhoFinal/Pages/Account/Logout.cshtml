@page
@model Versao1TrabalhoFinal.Areas.Identity.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Terminar sessão";
}

<section class="auth-page">
    <div class="auth-container">
        <div class="auth-card auth-card-sm">
            <div class="auth-brand">
                <a asp-page="/Index" class="auth-logo-link">
                    <img src="https://www.hsn-automoveis.pt/images/logo.png" alt="Logo Stand Premium" class="auth-logo" />
                </a>

                <h1 class="auth-title">Terminar sessão</h1>
                <p class="auth-subtitle">Tem a certeza que pretende terminar a sessão?</p>
            </div>

            <form method="post" class="auth-form">
                <input type="hidden" asp-for="ReturnUrl" />

                <button type="submit" class="auth-button auth-button-danger">
                    Sair
                </button>

                <a asp-page="/Index" class="auth-button auth-button-secondary text-center">
                    Cancelar
                </a>
            </form>
        </div>
    </div>
</section>

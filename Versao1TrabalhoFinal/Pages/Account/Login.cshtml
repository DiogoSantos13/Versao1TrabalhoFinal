@page
@model Versao1TrabalhoFinal.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar sessão";
}

<section class="auth-page">
    <div class="auth-overlay"></div>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-brand">
                <a asp-page="/Index" class="auth-logo-link">
                    <img src="https://www.hsn-automoveis.pt/images/logo.png" alt="Logo Stand Premium" class="auth-logo" />
                </a>
                <h1 class="auth-title">Iniciar sessão</h1>
                <p class="auth-subtitle">Acede ao sistema do stand e oficina.</p>
            </div>

            <form method="post" class="auth-form">
                <input type="hidden" asp-for="ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

                <div class="auth-field">
                    <label asp-for="Input.Email" class="auth-label"></label>
                    <input asp-for="Input.Email" class="auth-input" placeholder="exemplo@email.pt" />
                    <span asp-validation-for="Input.Email" class="auth-error"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Password" class="auth-label"></label>
                    <input asp-for="Input.Password" class="auth-input" placeholder="Introduza a palavra-passe" />
                    <span asp-validation-for="Input.Password" class="auth-error"></span>
                </div>

                <div class="auth-options">
                    <div class="auth-check">
                        <input asp-for="Input.RememberMe" class="auth-check-input" />
                        <label asp-for="Input.RememberMe" class="auth-check-label"></label>
                    </div>
                </div>

                <button type="submit" class="auth-button">Entrar</button>

                <div class="auth-links">
                    <a asp-page="/Account/Registar">Criar conta</a>
                    <a asp-page="/Index">Voltar ao início</a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

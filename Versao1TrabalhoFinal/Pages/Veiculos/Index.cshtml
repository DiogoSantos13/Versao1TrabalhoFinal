@page
@model Versao1TrabalhoFinal.Pages.Veiculos.IndexModel
@{
    ViewData["Title"] = "Os Meus Veículos";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="list-header">
            <div>
                <p class="page-eyebrow">Área do cliente</p>
                <h1 class="page-title">Os meus veículos</h1>
                <p class="page-subtitle">Consulte e gira os veículos associados à sua conta.</p>
            </div>

            <a asp-page="./Create" class="auth-button list-header-button">
                Novo veículo
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="success-banner">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (Model.Veiculos != null && Model.Veiculos.Any())
        {
            <div class="vehicle-grid">
                @foreach (var item in Model.Veiculos)
                {
                    <div class="vehicle-admin-card">
                        <div class="vehicle-admin-image-wrap">
                            <img src="@(string.IsNullOrWhiteSpace(item.ImagemUrl) ? "/images/cars/default-car.jpg" : item.ImagemUrl)"
                                 class="vehicle-admin-image"
                                 alt="@item.Marca @item.Modelo" />
                        </div>

                        <div class="vehicle-admin-body">
                            <h3 class="vehicle-admin-title">@item.Marca @item.Modelo</h3>

                            <p class="vehicle-admin-status">
                                @(string.IsNullOrWhiteSpace(item.Combustivel) ? "Veículo" : item.Combustivel)
                            </p>

                            <div class="vehicle-admin-meta">
                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Ano</span>
                                    <strong>@item.Ano</strong>
                                </div>

                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Matrícula</span>
                                    <strong>@(string.IsNullOrWhiteSpace(item.Matricula) ? "-" : item.Matricula)</strong>
                                </div>
                            </div>

                            <div class="vehicle-admin-actions">
                                <a asp-page="./Details" asp-route-id="@item.Id" class="action-link action-link-primary">
                                    Ver
                                </a>

                                <a asp-page="./Edit" asp-route-id="@item.Id" class="action-link action-link-primary">
                                    Editar
                                </a>

                                <a asp-page="./Delete" asp-route-id="@item.Id" class="action-link action-link-danger">
                                    Eliminar
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state-card">
                <h3>Sem veículos registados</h3>
                <p>Ainda não tem veículos associados à sua conta.</p>
                <a asp-page="./Create" class="auth-button">Adicionar primeiro veículo</a>
            </div>
        }
    </div>
</section>

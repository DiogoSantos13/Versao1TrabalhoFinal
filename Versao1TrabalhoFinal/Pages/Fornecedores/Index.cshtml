@page
@model Versao1TrabalhoFinal.Pages.Fornecedores.IndexModel
@{
    ViewData["Title"] = "Fornecedores";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Fornecedores</h2>
    <a asp-page="./Create" class="btn btn-primary">Novo Fornecedor</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Telefone</th>
                        <th>Email</th>
                        <th>Morada</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Fornecedores)
                    {
                        <tr>
                            <td>@item.Nome</td>
                            <td>@item.Telefone</td>
                            <td>@item.Email</td>
                            <td>@item.Morada</td>
                            <td class="text-end">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Editar</a>
                                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

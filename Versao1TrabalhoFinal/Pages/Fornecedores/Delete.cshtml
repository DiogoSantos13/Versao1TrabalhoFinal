@page "{id:int}"
@model Versao1TrabalhoFinal.Pages.Fornecedores.DeleteModel
@{
    ViewData["Title"] = "Eliminar Fornecedor";
}

<div class="card shadow-sm">
    <div class="card-body">
        <h2 class="text-danger">Eliminar fornecedor</h2>
        <p>Tens a certeza que queres eliminar este fornecedor?</p>

        <dl class="row">
            <dt class="col-sm-2">Nome</dt>
            <dd class="col-sm-10">@Model.Fornecedor.Nome</dd>

            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@Model.Fornecedor.Email</dd>
        </dl>

        <form method="post">
            <button type="submit" class="btn btn-danger">Eliminar</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </div>
</div>

@page
@model Versao1TrabalhoFinal.Pages.Produtos.CreateModel
@{
    ViewData["Title"] = "Criar Produto";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="page-header-block">
            <p class="page-eyebrow">Administração</p>
            <h1 class="page-title">Novo produto</h1>
            <p class="page-subtitle">Adicione um novo produto ao catálogo da loja.</p>
        </div>

        <div class="client-edit-layout">
            <div class="client-edit-main">
                <div class="client-form-card">
                    <form method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="auth-validation mb-4"></div>

                        <div class="client-form-grid">
                            <div class="client-field client-field-full">
                                <label asp-for="Produto.Nome" class="client-label"></label>
                                <input asp-for="Produto.Nome" class="client-input" />
                                <span asp-validation-for="Produto.Nome" class="text-danger"></span>
                            </div>

                            <div class="client-field client-field-full">
                                <label asp-for="Produto.Descricao" class="client-label"></label>
                                <textarea asp-for="Produto.Descricao" class="client-input client-textarea" rows="6"></textarea>
                                <span asp-validation-for="Produto.Descricao" class="text-danger"></span>
                            </div>

                            <div class="client-field">
                                <label asp-for="Produto.Preco" class="client-label"></label>
                                <input asp-for="Produto.Preco" class="client-input" />
                                <span asp-validation-for="Produto.Preco" class="text-danger"></span>
                            </div>

                            <div class="client-field">
                                <label asp-for="Produto.Stock" class="client-label"></label>
                                <input asp-for="Produto.Stock" class="client-input" />
                                <span asp-validation-for="Produto.Stock" class="text-danger"></span>
                            </div>

                            <div class="client-field">
                                <label asp-for="Produto.Categoria" class="client-label"></label>
                                <input asp-for="Produto.Categoria" class="client-input" />
                                <span asp-validation-for="Produto.Categoria" class="text-danger"></span>
                            </div>

                            <div class="client-field">
                                <label asp-for="Produto.FornecedorId" class="client-label">Fornecedor</label>
                                <select asp-for="Produto.FornecedorId" asp-items="Model.FornecedoresOptions" class="client-input">
                                    <option value="">Selecione um fornecedor</option>
                                </select>
                                <span asp-validation-for="Produto.FornecedorId" class="text-danger"></span>
                            </div>

                            <div class="client-field client-field-full">
                                <label asp-for="UploadImagens" class="client-label">Imagens do Produto</label>
                                <input asp-for="UploadImagens" type="file" multiple accept="image/*" class="client-input" />
                                <span asp-validation-for="UploadImagens" class="text-danger"></span>
                                <small class="text-muted">Pode selecionar várias imagens.</small>
                            </div>

                            <div class="client-field">
                                <label asp-for="Produto.MarcaVeiculo" class="client-label"></label>
                                <input asp-for="Produto.MarcaVeiculo" class="client-input" />
                                <span asp-validation-for="Produto.MarcaVeiculo" class="text-danger"></span>
                            </div>

                            <div class="client-field">
                                <label asp-for="Produto.ModeloVeiculo" class="client-label"></label>
                                <input asp-for="Produto.ModeloVeiculo" class="client-input" />
                                <span asp-validation-for="Produto.ModeloVeiculo" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="client-form-actions">
                            <button type="submit" class="auth-button">
                                <i class="fa-solid fa-floppy-disk"></i>
                                <span>Guardar produto</span>
                            </button>

                            <a asp-page="./Index" class="auth-button auth-button-secondary">
                                <i class="fa-solid fa-arrow-left"></i>
                                <span>Cancelar</span>
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <aside class="client-edit-side">
                <div class="client-summary-card">
                    <h3 class="client-summary-name">Catálogo</h3>
                    <p class="client-summary-email">Preencha todos os dados do produto para o disponibilizar na loja.</p>
                </div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
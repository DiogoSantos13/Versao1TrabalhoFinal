@page "{id:int}"
@model Versao1TrabalhoFinal.Pages.Produtos.DeleteModel
@{
    ViewData["Title"] = "Eliminar Produto";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="text-danger mb-3">Eliminar produto</h2>
                <p class="mb-4">Tens a certeza que queres eliminar este produto?</p>

                <div class="border rounded p-3 bg-light mb-4">
                    <p><strong>Nome:</strong> @Model.Produto.Nome</p>
                    <p><strong>Categoria:</strong> @Model.Produto.Categoria</p>
                    <p><strong>Fornecedor:</strong> @Model.Produto.Fornecedor?.Nome</p>
                    <p><strong>Preço:</strong> € @Model.Produto.Preco</p>
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Produto.Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Eliminar</button>
                        <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

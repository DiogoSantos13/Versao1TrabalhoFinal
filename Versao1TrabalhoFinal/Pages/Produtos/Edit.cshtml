@page "{id:int}"
@model Versao1TrabalhoFinal.Pages.Produtos.EditModel

@{
    ViewData["Title"] = "Editar Produto";

    var imagemPrincipal = Model.Produto.Imagens?
        .OrderByDescending(i => i.Principal)
        .ThenBy(i => i.Ordem)
        .FirstOrDefault();

    var imagemPreview = imagemPrincipal != null
        ? Url.Content(imagemPrincipal.Url)
        : Url.Content("~/images/produtos/sem-imagem.png");
}

<div class="produto-edit-page py-4 py-lg-5">
    <div class="produto-edit-shell">
        <section class="produto-edit-hero mb-4">
            <div class="produto-edit-hero-content">
                <div>
                    <span class="produto-edit-kicker">Gestão de produtos</span>
                    <h1 class="produto-edit-title">Editar produto</h1>
                    <p class="produto-edit-subtitle">
                        Atualize os dados do produto, mantenha a informação organizada e gira a galeria de imagens.
                    </p>
                </div>

                <div class="produto-edit-hero-actions">
                    <a asp-page="./Index" class="btn produto-btn-light">
                        <i class="fa-solid fa-arrow-left me-2"></i>
                        Voltar à lista
                    </a>
                </div>
            </div>
        </section>

        <form method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Produto.Id" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm rounded-4 mb-4"></div>

            <div class="row g-4">
                <div class="col-12 col-xl-8">
                    <div class="produto-form-card mb-4">
                        <div class="produto-form-card-header">
                            <h2>Informação principal</h2>
                            <p>Edite o nome e a descrição base do produto.</p>
                        </div>

                        <div class="produto-form-card-body">
                            <div class="mb-3">
                                <label asp-for="Produto.Nome" class="form-label produto-form-label"></label>
                                <input asp-for="Produto.Nome" class="form-control produto-form-input" />
                                <span asp-validation-for="Produto.Nome" class="text-danger small"></span>
                            </div>

                            <div class="mb-0">
                                <label asp-for="Produto.Descricao" class="form-label produto-form-label"></label>
                                <textarea asp-for="Produto.Descricao" class="form-control produto-form-input produto-textarea" rows="5"></textarea>
                                <span asp-validation-for="Produto.Descricao" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="produto-form-card mb-4">
                        <div class="produto-form-card-header">
                            <h2>Preço e stock</h2>
                            <p>Atualize valores comerciais e categoria do produto.</p>
                        </div>

                        <div class="produto-form-card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="Produto.Preco" class="form-label produto-form-label"></label>
                                    <input asp-for="Produto.Preco"
                                           class="form-control produto-form-input"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           inputmode="decimal" />
                                    <span asp-validation-for="Produto.Preco" class="text-danger small"></span>
                                    <div class="form-text">Exemplo: 12,50</div>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Produto.Stock" class="form-label produto-form-label"></label>
                                    <input asp-for="Produto.Stock" class="form-control produto-form-input" />
                                    <span asp-validation-for="Produto.Stock" class="text-danger small"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Produto.Categoria" class="form-label produto-form-label"></label>
                                    <input asp-for="Produto.Categoria" class="form-control produto-form-input" />
                                    <span asp-validation-for="Produto.Categoria" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="produto-form-card mb-4">
                        <div class="produto-form-card-header">
                            <h2>Compatibilidade</h2>
                            <p>Associe o produto à marca, modelo e fornecedor correspondente.</p>
                        </div>

                        <div class="produto-form-card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="Produto.MarcaVeiculo" class="form-label produto-form-label"></label>
                                    <input asp-for="Produto.MarcaVeiculo" class="form-control produto-form-input" />
                                    <span asp-validation-for="Produto.MarcaVeiculo" class="text-danger small"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Produto.ModeloVeiculo" class="form-label produto-form-label"></label>
                                    <input asp-for="Produto.ModeloVeiculo" class="form-control produto-form-input" />
                                    <span asp-validation-for="Produto.ModeloVeiculo" class="text-danger small"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Produto.FornecedorId" class="form-label produto-form-label">Fornecedor</label>
                                    <select asp-for="Produto.FornecedorId"
                                            asp-items="Model.FornecedoresSelect"
                                            class="form-select produto-form-input">
                                    </select>
                                    <span asp-validation-for="Produto.FornecedorId" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="produto-form-card mb-4">
                        <div class="produto-form-card-header">
                            <h2>Adicionar novas imagens</h2>
                            <p>Selecione uma ou várias imagens para juntar à galeria atual.</p>
                        </div>

                        <div class="produto-form-card-body">
                            <div class="mb-0">
                                <label asp-for="UploadImagens" class="form-label produto-form-label">Novas imagens</label>
                                <input asp-for="UploadImagens" type="file" multiple accept="image/*" class="form-control produto-form-input" />
                                <span asp-validation-for="UploadImagens" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="produto-form-card">
                        <div class="produto-form-card-header">
                            <h2>Galeria atual</h2>
                            <p>Defina a imagem principal ou remova imagens da galeria.</p>
                        </div>

                        <div class="produto-form-card-body">
                            @if (Model.Produto.Imagens != null && Model.Produto.Imagens.Any())
                            {
                                <div class="row g-3">
                                    @foreach (var imagem in Model.Produto.Imagens.OrderByDescending(i => i.Principal).ThenBy(i => i.Ordem))
                                    {
                                        <div class="col-md-6 col-lg-4">
                                            <div class="border rounded-4 p-3 h-100">
                                                <img src="@Url.Content(imagem.Url)"
                                                     alt="@imagem.Alt"
                                                     class="img-fluid rounded-3 mb-3"
                                                     style="height:200px; width:100%; object-fit:cover;"
                                                     onerror="this.onerror=null;this.src='@Url.Content("~/images/produtos/sem-imagem.png")';" />

                                                <div class="d-flex flex-column gap-2">
                                                    @if (imagem.Principal)
                                                    {
                                                        <span class="badge bg-success">Imagem principal</span>
                                                    }
                                                    else
                                                    {
                                                        <form method="post" asp-page-handler="DefinirPrincipal">
                                                            <input type="hidden" name="id" value="@Model.Produto.Id" />
                                                            <input type="hidden" name="imagemId" value="@imagem.Id" />
                                                            <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                                                                Definir como principal
                                                            </button>
                                                        </form>
                                                    }

                                                    <form method="post" asp-page-handler="DeleteImagem" onsubmit="return confirm('Tem a certeza que deseja remover esta imagem?');">
                                                        <input type="hidden" name="id" value="@Model.Produto.Id" />
                                                        <input type="hidden" name="imagemId" value="@imagem.Id" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                                            Remover imagem
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0">Este produto ainda não tem imagens associadas.</p>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-4">
                    <div class="produto-form-card mb-4 sticky-xl-top produto-sticky-card">
                        <div class="produto-form-card-header">
                            <h2>Pré-visualização</h2>
                            <p>Imagem principal atual do produto no catálogo.</p>
                        </div>

                        <div class="produto-form-card-body">
                            <div class="produto-preview-box mb-3">
                                <img src="@imagemPreview"
                                     alt="@Model.Produto.Nome"
                                     class="produto-preview-image"
                                     onerror="this.onerror=null;this.src='@Url.Content("~/images/produtos/sem-imagem.png")';" />
                            </div>

                            <div class="form-text">
                                A imagem principal será usada como destaque visual do produto.
                            </div>
                        </div>
                    </div>

                    <div class="produto-form-card">
                        <div class="produto-form-card-header">
                            <h2>Ações</h2>
                            <p>Guarde as alterações ou volte sem modificar.</p>
                        </div>

                        <div class="produto-form-card-body">
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn produto-btn-primary">
                                    <i class="fa-solid fa-floppy-disk me-2"></i>
                                    Guardar alterações
                                </button>

                                <a asp-page="./Index" class="btn produto-btn-light">
                                    <i class="fa-solid fa-xmark me-2"></i>
                                    Cancelar
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@page "{id:int}"
@model Versao1TrabalhoFinal.Pages.Servicos.DeleteModel
@{
    ViewData["Title"] = "Eliminar Serviço";
}

<h2 class="mb-4">Eliminar Serviço</h2>

@if (Model.Servico != null)
{
    <div class="alert alert-warning">
        Tem a certeza que pretende eliminar este serviço?
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h4>@Model.Servico.Nome</h4>
            <p class="text-muted">@Model.Servico.Descricao</p>
            <p><strong>Preço base:</strong> € @Model.Servico.PrecoBase</p>
            <p><strong>Tempo estimado:</strong> @Model.Servico.TempoEstimado min</p>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Servico.Id" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-page="/Servicos/Index" class="btn btn-secondary">Cancelar</a>
    </form>
}

@page "{id:int}"
@model Versao1TrabalhoFinal.Pages.Servicos.EditModel
@{
    ViewData["Title"] = "Editar Serviço";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="mb-4">Editar serviço</h2>

                <form method="post">
                    <input type="hidden" asp-for="Servico.Id" />

                    <div class="mb-3">
                        <label asp-for="Servico.Nome" class="form-label"></label>
                        <input asp-for="Servico.Nome" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Servico.Descricao" class="form-label"></label>
                        <textarea asp-for="Servico.Descricao" class="form-control"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Servico.PrecoBase" class="form-label"></label>
                            <input asp-for="Servico.PrecoBase" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Servico.TempoEstimado" class="form-label"></label>
                            <input asp-for="Servico.TempoEstimado" class="form-control" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Servico.ImagemUrl" class="form-label"></label>
                        <input asp-for="Servico.ImagemUrl" class="form-control" />
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="Servico.Ativo" class="form-check-input" />
                        <label asp-for="Servico.Ativo" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary">Guardar alterações</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>

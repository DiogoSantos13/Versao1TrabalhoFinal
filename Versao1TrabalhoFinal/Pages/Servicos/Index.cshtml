@page
@model Versao1TrabalhoFinal.Pages.Servicos.IndexModel
@{
    ViewData["Title"] = "Serviços";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="page-header-block d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <p class="page-eyebrow">Gestão interna</p>
                <h1 class="page-title">Serviços</h1>
                <p class="page-subtitle">Consulte e gira os serviços disponíveis na oficina.</p>
            </div>

            <div>
                <a asp-page="/Servicos/Create" class="auth-button">Novo serviço</a>
            </div>
        </div>

        @if (Model.Servicos.Any())
        {
            <div class="vehicle-grid">
                @foreach (var servico in Model.Servicos)
                {
                    <div class="vehicle-admin-card">
                        <div class="vehicle-admin-image-wrap">
                            <img src="@(string.IsNullOrWhiteSpace(servico.ImagemUrl) ? "/images/cars/default-car.jpg" : servico.ImagemUrl)"
                                 class="vehicle-admin-image"
                                 alt="@servico.Nome" />
                        </div>

                        <div class="vehicle-admin-body">
                            <h3 class="vehicle-admin-title">@servico.Nome</h3>

                            <p class="vehicle-admin-status">
                                @(servico.Ativo ? "Ativo" : "Inativo")
                            </p>

                            <p class="page-subtitle mb-3">@servico.Descricao</p>

                            <div class="vehicle-admin-meta">
                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Preço base</span>
                                    <strong>€ @servico.PrecoBase.ToString("N2")</strong>
                                </div>

                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Tempo estimado</span>
                                    <strong>@servico.TempoEstimado min</strong>
                                </div>
                            </div>

                            <div class="vehicle-admin-actions">
                                <a asp-page="/Servicos/Details" asp-route-id="@servico.Id" class="action-link action-link-primary">
                                    Detalhes
                                </a>

                                <a asp-page="/Servicos/Edit" asp-route-id="@servico.Id" class="action-link action-link-warning">
                                    Editar
                                </a>

                                <a asp-page="/Servicos/Delete" asp-route-id="@servico.Id" class="action-link action-link-danger">
                                    Eliminar
                                </a>
                                @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Cliente"))
                                {
                                    <a href="/Carrinho/AdicionarServico?servicoId=@servico.Id"
                                       class="action-link action-link-primary">
                                        Adicionar ao carrinho
                                    </a>

                                }

                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state-card">
                <h3>Sem serviços registados</h3>
                <p>Ainda não existem serviços criados no sistema.</p>
                <a asp-page="/Servicos/Create" class="auth-button">Criar primeiro serviço</a>
            </div>
        }
    </div>
</section>

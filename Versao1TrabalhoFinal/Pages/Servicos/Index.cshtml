@page
@model Versao1TrabalhoFinal.Pages.Servicos.IndexModel
@{
    ViewData["Title"] = "Serviços";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Serviços</h2>
    <a asp-page="/Servicos/Create" class="btn btn-success">Novo Serviço</a>
</div>

<div class="row g-4">
    @foreach (var servico in Model.Servicos)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrWhiteSpace(servico.ImagemUrl))
                {
                    <img src="@servico.ImagemUrl" class="card-img-top" style="height:220px; object-fit:cover;" alt="@servico.Nome" />
                }
                <div class="card-body">
                    <h5>@servico.Nome</h5>
                    <p class="text-muted">@servico.Descricao</p>
                    <p><strong>Preço base:</strong> € @servico.PrecoBase</p>
                    <p><strong>Tempo:</strong> @servico.TempoEstimado min</p>
                    <p>
                        @if (servico.Ativo)
                        {
                            <span class="badge bg-success">Ativo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inativo</span>
                        }
                    </p>
                </div>
            </div>
        </div>
    }
</div>

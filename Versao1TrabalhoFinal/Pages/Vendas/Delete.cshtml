@page "{id:int}"
@model Versao1TrabalhoFinal.Pages.Vendas.DeleteModel
@{
    ViewData["Title"] = "Eliminar Venda";
}

<div class="card shadow-sm">
    <div class="card-body">
        <h2 class="text-danger">Eliminar venda</h2>
        <p>Tens a certeza que queres eliminar esta venda?</p>

        <dl class="row">
            <dt class="col-sm-2">Cliente</dt>
            <dd class="col-sm-10">@Model.Venda.Cliente?.Nome</dd>

            <dt class="col-sm-2">Total</dt>
            <dd class="col-sm-10">€ @Model.Venda.Total</dd>
        </dl>

        <form method="post">
            <button type="submit" class="btn btn-danger">Eliminar</button>
            <a asp-page="./Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </div>
</div>

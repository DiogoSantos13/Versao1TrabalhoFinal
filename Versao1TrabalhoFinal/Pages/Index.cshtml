@page
@model Versao1TrabalhoFinal.Pages.VeiculosStand.IndexModel
@{
    ViewData["Title"] = "Veículos do Stand";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="list-header">
            <div>
                <p class="page-eyebrow">Stand automóvel</p>
                <h1 class="page-title">Veículos disponíveis</h1>
                <p class="page-subtitle">Explore o stock atualmente disponível no stand.</p>
            </div>

            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
            {
                <a asp-page="/VeiculosStand/Create" class="auth-button list-header-button">
                    Novo veículo do stand
                </a>
            }
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="success-banner">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="error-banner">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (Model.VeiculosStand != null && Model.VeiculosStand.Any())
        {
            <div class="vehicle-grid">
                @foreach (var item in Model.VeiculosStand)
                {
                    var imagens = item.Imagens?
                    .OrderByDescending(i => i.Principal)
                    .ThenBy(i => i.Ordem)
                    .ToList() ?? new List<Versao1TrabalhoFinal.Models.ImagemEntidade>();

                    if (!imagens.Any() && !string.IsNullOrWhiteSpace(item.Veiculo?.ImagemUrl))
                    {
                        imagens.Add(new Versao1TrabalhoFinal.Models.ImagemEntidade
                        {
                            Url = item.Veiculo.ImagemUrl,
                            Alt = $"{item.Veiculo?.Marca} {item.Veiculo?.Modelo}",
                            Principal = true,
                            Ordem = 0
                        });
                    }

                    if (!imagens.Any())
                    {
                        imagens.Add(new Versao1TrabalhoFinal.Models.ImagemEntidade
                        {
                            Url = Url.Content("~/images/cars/default-car.jpg"),
                            Alt = "Imagem por defeito",
                            Principal = true,
                            Ordem = 0
                        });
                    }

                    var titulo = $"{item.Veiculo?.Marca ?? "Veículo"} {item.Veiculo?.Modelo ?? ""}".Trim();
                    var combustivel = string.IsNullOrWhiteSpace(item.Veiculo?.Combustivel) ? "-" : item.Veiculo?.Combustivel;
                    var estado = string.IsNullOrWhiteSpace(item.Estado) ? "Disponível" : item.Estado;
                    var carouselId = $"carousel-{item.Id}";
                    <article class="vehicle-admin-card">
                        <div class="vehicle-carousel" id="@carouselId">
                            <div class="vehicle-carousel-track">
                                @for (int i = 0; i < imagens.Count; i++)
                                {
                                    var imagem = imagens[i];
                                    <div class="vehicle-carousel-slide @(i == 0 ? "active" : "")" data-index="@i">
                                        <img src="@imagem.Url"
                                             class="vehicle-admin-image"
                                             alt="@(string.IsNullOrWhiteSpace(imagem.Alt) ? titulo : imagem.Alt)"
                                             onerror="this.onerror=null;this.src='@Url.Content("~/images/cars/default-car.jpg")';" />
                                    </div>
                                }
                            </div>

                            @if (imagens.Count > 1)
                            {
                                <button type="button" class="carousel-arrow carousel-arrow-left" data-direction="prev" aria-label="Imagem anterior">
                                    &#8249;
                                </button>

                                <button type="button" class="carousel-arrow carousel-arrow-right" data-direction="next" aria-label="Imagem seguinte">
                                    &#8250;
                                </button>

                                <div class="carousel-counter">
                                    <span class="current-slide">1</span>/<span class="total-slides">@imagens.Count</span>
                                </div>
                            }
                        </div>

                        <div class="vehicle-admin-body">
                            <h3 class="vehicle-admin-title">@titulo</h3>

                            <p class="vehicle-admin-status @(estado.ToLower().Contains("vendido") ? "status-sold" : "status-available")">
                                @estado
                            </p>

                            <div class="vehicle-admin-meta">
                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Preço</span>
                                    <strong>€ @item.Preco.ToString("N2")</strong>
                                </div>

                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Quilómetros</span>
                                    <strong>@item.Quilometros.ToString("N0")</strong>
                                </div>
                            </div>

                            <div class="vehicle-admin-meta">
                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Ano</span>
                                    <strong>@(item.Veiculo?.Ano)</strong>
                                </div>

                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Combustível</span>
                                    <strong>@combustivel</strong>
                                </div>
                            </div>

                            <div class="vehicle-admin-actions">
                                <a asp-page="/VeiculosStand/Details"
                                   asp-route-id="@item.Id"
                                   class="action-link action-link-primary">
                                    Detalhes
                                </a>

                                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                                {
                                    <a asp-page="/VeiculosStand/Edit"
                                       asp-route-id="@item.Id"
                                       class="action-link action-link-primary">
                                        Editar
                                    </a>

                                    <a asp-page="/VeiculosStand/Delete"
                                       asp-route-id="@item.Id"
                                       class="action-link action-link-danger">
                                        Eliminar
                                    </a>
                                }
                                else
                                {
                                    if (User.Identity != null && User.Identity.IsAuthenticated)
                                    {
                                        <a asp-page="/Carrinho/Adicionar"
                                           asp-route-veiculoStandId="@item.Id"
                                           class="action-link action-link-primary">
                                            Adicionar ao carrinho
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-page="/Account/Login"
                                           asp-route-returnUrl="@Url.Page("/VeiculosStand/Index")"
                                           class="action-link action-link-primary">
                                            Iniciar sessão
                                        </a>
                                    }
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="empty-state-card">
                <h3>Sem veículos em stock</h3>
                <p>Não existem viaturas disponíveis para mostrar neste momento.</p>

                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <a asp-page="/VeiculosStand/Create" class="auth-button">
                        Adicionar veículo ao stand
                    </a>
                }
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        (function () {
            const carousels = document.querySelectorAll('.vehicle-carousel');

            carousels.forEach(carousel => {
                const slides = carousel.querySelectorAll('.vehicle-carousel-slide');
                const prevButton = carousel.querySelector('.carousel-arrow-left');
                const nextButton = carousel.querySelector('.carousel-arrow-right');
                const currentSlideElement = carousel.querySelector('.current-slide');

                if (!slides.length) return;

                let currentIndex = 0;

                function updateCarousel() {
                    slides.forEach((slide, index) => {
                        slide.classList.toggle('active', index === currentIndex);
                    });

                    if (currentSlideElement) {
                        currentSlideElement.textContent = (currentIndex + 1).toString();
                    }
                }

                if (prevButton) {
                    prevButton.addEventListener('click', function () {
                        currentIndex = (currentIndex - 1 + slides.length) % slides.length;
                        updateCarousel();
                    });
                }

                if (nextButton) {
                    nextButton.addEventListener('click', function () {
                        currentIndex = (currentIndex + 1) % slides.length;
                        updateCarousel();
                    });
                }

                updateCarousel();
            });
        })();
    </script>
}
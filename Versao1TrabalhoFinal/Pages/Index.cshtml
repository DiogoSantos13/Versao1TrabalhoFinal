@page
@model Versao1TrabalhoFinal.Pages.IndexModel
@{
    ViewData["Title"] = "Stand e Oficina Automóvel - Stand Premium";
}

<section class="hero">
    <h1>
        SOMOS <span>ESPECIALISTAS EM OPORTUNIDADES</span>,<br />
        COM UM SERVIÇO DE QUALIDADE COMPLETO.
    </h1>
    <p class="hero-subtitle">
        Descubra as últimas entradas em stock, os nossos serviços e os produtos disponíveis para o seu veículo.
    </p>
</section>

<section class="stock-section">
    <div class="section-title">
        <p>Os mais recentes</p>
        <h2>Últimas Entradas</h2>
    </div>

    <div class="swiper swiper-container-stock">
        <div class="swiper-wrapper">
            @if (Model.VeiculosDestaque != null && Model.VeiculosDestaque.Any())
            {
                foreach (var veiculo in Model.VeiculosDestaque)
                {
                    <div class="swiper-slide">
                        <a asp-page="/VeiculosStand/Details" asp-route-id="@veiculo.Id" class="stock-card-link">
                            <div class="destaques_box">
                                <div class="image-container">
                                    <img src="@(string.IsNullOrWhiteSpace(veiculo.ImagemUrl) ? "/images/cars/default-car.jpg" : veiculo.ImagemUrl)"
                                         alt="Veículo @veiculo.Id" />

                                    <div class="carro_listagem_specs">
                                        <div class="destaques_listagem_specs_item">
                                            <i class="fa-regular fa-calendar"></i>
                                            @veiculo.DataEntrada.ToString("MMM. yyyy")
                                        </div>

                                        <div class="destaques_listagem_specs_item">
                                            <i class="fa-solid fa-circle-check"></i>
                                            @(string.IsNullOrWhiteSpace(veiculo.Estado) ? "Disponível" : veiculo.Estado)
                                        </div>

                                        <div class="destaques_listagem_specs_item">
                                            <i class="fa-solid fa-road"></i>
                                            @veiculo.Quilometros.ToString("N0") KM
                                        </div>
                                    </div>
                                </div>

                                <div class="listagem_info">
                                    <div class="destaques_texto_listagem_marca">Viatura</div>
                                    <div class="destaques_texto_listagem_modelo">
                                        @(string.IsNullOrWhiteSpace(veiculo.Descricao) ? $"Stock #{veiculo.Id}" : veiculo.Descricao)
                                    </div>
                                    <div class="destaques_nocampanha">Preço</div>
                                    <div class="boxPrecoFicha">
                                        <span>@veiculo.Preco.ToString("N0")</span> €
                                    </div>
                                    <div class="carro_Mais">
                                        <svg width="22" height="4" fill="#ccc" aria-hidden="true">
                                            <circle cx="2" cy="2" r="2"></circle>
                                            <circle cx="11" cy="2" r="2"></circle>
                                            <circle cx="20" cy="2" r="2"></circle>
                                        </svg>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="swiper-slide">
                    <div class="destaques_box">
                        <div class="image-container">
                            <img src="/images/cars/default-car.jpg" alt="Sem veículos" />
                        </div>
                        <div class="listagem_info">
                            <div class="destaques_texto_listagem_marca">Sem stock</div>
                            <div class="destaques_texto_listagem_modelo">
                                Não existem viaturas disponíveis para mostrar neste momento.
                            </div>
                            <div class="destaques_nocampanha">Informação</div>
                            <div class="boxPrecoFicha">
                                <span>0</span> €
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="swiper-pagination"></div>
    </div>
</section>

<section class="stock-section">
    <div class="section-title">
        <p>Oficina</p>
        <h2>Serviços em destaque</h2>
    </div>

    <div class="vehicle-grid">
        @if (Model.ServicosDestaque != null && Model.ServicosDestaque.Any())
        {
            foreach (var servico in Model.ServicosDestaque)
            {
                <div class="vehicle-admin-card">
                    <div class="vehicle-admin-body pt-4">
                        <h3 class="vehicle-admin-title">@servico.Nome</h3>

                        <p class="page-subtitle">
                            @(string.IsNullOrWhiteSpace(servico.Descricao)
                                                ? "Serviço disponível na nossa oficina."
                                                : servico.Descricao)
                </p>

                        <div class="vehicle-admin-meta">
                            <div class="vehicle-admin-meta-item">
                                <span class="vehicle-admin-meta-label">Preço base</span>
                                <strong>€ @servico.PrecoBase.ToString("N2")</strong>
                            </div>

                            <div class="vehicle-admin-meta-item">
                                <span class="vehicle-admin-meta-label">Tempo estimado</span>
                                <strong>@servico.TempoEstimado min</strong>
                            </div>
                        </div>

                        <div class="vehicle-admin-actions">
                            <a asp-page="/Servicos/Index" class="action-link action-link-primary">
                                Ver serviços
                            </a>
                        </div>
                    </div>
                </div>
                }
        }
        else
        {
            <div class="empty-state-card">
                <h3>Sem serviços em destaque</h3>
                <p>Não existem serviços disponíveis para apresentar neste momento.</p>
            </div>
        }
    </div>
</section>

<section class="stock-section">
    <div class="section-title">
        <p>Loja</p>
        <h2>Produtos em destaque</h2>
    </div>

    <div class="vehicle-grid">
        @if (Model.ProdutosDestaque != null && Model.ProdutosDestaque.Any())
        {
            foreach (var produto in Model.ProdutosDestaque)
            {
                <div class="vehicle-admin-card">
                    <div class="vehicle-admin-image-wrap">
                        <img src="@(string.IsNullOrWhiteSpace(produto.ImagemUrl) ? "/images/products/default-product.jpg" : produto.ImagemUrl)"
                             class="vehicle-admin-image"
                             alt="@(produto.Nome ?? "Produto")" />
                    </div>

                    <div class="vehicle-admin-body">
                        <h3 class="vehicle-admin-title">@produto.Nome</h3>

                        <p class="page-subtitle">
                            @(string.IsNullOrWhiteSpace(produto.Descricao)
                                                ? "Produto disponível para o seu veículo."
                                                : produto.Descricao)
                </p>

                        <div class="vehicle-admin-meta">
                            <div class="vehicle-admin-meta-item">
                                <span class="vehicle-admin-meta-label">Preço</span>
                                <strong>€ @produto.Preco.ToString("N2")</strong>
                            </div>

                            <div class="vehicle-admin-meta-item">
                                <span class="vehicle-admin-meta-label">Stock</span>
                                <strong>@produto.Stock</strong>
                            </div>
                        </div>

                        <div class="vehicle-admin-actions">
                            <a asp-page="/Produtos/Index" class="action-link action-link-primary">
                                Ver produtos
                            </a>
                        </div>
                    </div>
                </div>
                }
        }
        else
        {
            <div class="empty-state-card">
                <h3>Sem produtos em destaque</h3>
                <p>Não existem produtos disponíveis para apresentar neste momento.</p>
            </div>
        }
    </div>
</section>

<section class="map-section">
    <div class="map-card">
        <iframe class="map-iframe"
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3083.473534575!2d-8.4116!3d39.6015!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMznCsDM2JzA1LjQiTiA4wrAyNCc0MS44Ilc!5e0!3m2!1spt-PT!2spt!4v1700000000000"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade">
        </iframe>

        <div class="map-info">
            <h3>Onde estamos?</h3>

            <div class="contact-row">
                <i class="fa-solid fa-location-dot"></i>
                <div>
                    <span>Morada</span>
                    <p>Av. Dr. Aurélio Ribeiro, 42-A, 2300-305 Tomar</p>
                </div>
            </div>

            <div class="contact-row">
                <i class="fa-solid fa-phone"></i>
                <div>
                    <span>Telefone</span>
                    <p>+351 968 XXX XXX</p>
                </div>
            </div>

            <div class="contact-row">
                <i class="fa-solid fa-clock"></i>
                <div>
                    <span>Horário</span>
                    <p>Seg - Sex: 09:00 - 19:00</p>
                </div>
            </div>

            <a href="https://maps.google.com/?q=Av.+Dr.+Aurélio+Ribeiro,+42-A,+2300-305+Tomar"
               target="_blank"
               rel="noopener noreferrer"
               class="btn-map">
                OBTER DIREÇÕES
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new Swiper('.swiper-container-stock', {
                slidesPerView: 1,
                spaceBetween: 20,
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true
                },
                breakpoints: {
                    768: { slidesPerView: 2 },
                    1100: { slidesPerView: 3 }
                }
            });
        });
    </script>
}
@page "{id:int}"
@model Versao1TrabalhoFinal.Pages.Colaboradores.EditModel
@{
    ViewData["Title"] = "Editar Colaborador";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="page-header-block">
            <p class="page-eyebrow">Administração</p>
            <h1 class="page-title">Editar colaborador</h1>
            <p class="page-subtitle">Atualize os dados do colaborador e a respetiva role.</p>
        </div>

        <div class="client-form-card">
            <form method="post">
                @* 
                    Resumo global de erros de validação.
                    Mostra mensagens devolvidas pelo ModelState no PageModel.
                *@
                <div asp-validation-summary="ModelOnly" class="auth-validation mb-4"></div>

                @* 
                    Campos ocultos para manter o identificador do colaborador
                    e o ID do utilizador Identity associado.
                *@
                <input type="hidden" asp-for="Input.Id" />
                <input type="hidden" asp-for="Input.IdentityUserId" />

                <div class="client-form-grid">
                    <div class="client-field">
                        <label asp-for="Input.Nome" class="client-label"></label>
                        <input asp-for="Input.Nome" class="client-input" />
                        <span asp-validation-for="Input.Nome" class="text-danger"></span>
                    </div>

                    <div class="client-field">
                        <label asp-for="Input.Telefone" class="client-label"></label>
                        <input asp-for="Input.Telefone" class="client-input" />
                        <span asp-validation-for="Input.Telefone" class="text-danger"></span>
                    </div>

                    <div class="client-field client-field-full">
                        <label asp-for="Input.Email" class="client-label"></label>
                        <input asp-for="Input.Email" class="client-input" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="client-field">
                        <label asp-for="Input.Role" class="client-label"></label>
                        <select asp-for="Input.Role"
                                asp-items="Model.RolesDisponiveis"
                                class="client-input">
                        </select>
                        <span asp-validation-for="Input.Role" class="text-danger"></span>
                    </div>

                    <div class="client-field">
                        <label asp-for="Input.Cargo" class="client-label"></label>
                        <input asp-for="Input.Cargo" class="client-input" />
                        <span asp-validation-for="Input.Cargo" class="text-danger"></span>
                    </div>

                    <div class="client-field">
                        <label asp-for="Input.NIF" class="client-label"></label>
                        <input asp-for="Input.NIF" class="client-input" />
                        <span asp-validation-for="Input.NIF" class="text-danger"></span>
                    </div>

                    <div class="client-field">
                        <label asp-for="Input.ImagemUrl" class="client-label"></label>
                        <input asp-for="Input.ImagemUrl" class="client-input" />
                        <span asp-validation-for="Input.ImagemUrl" class="text-danger"></span>
                    </div>

                    <div class="client-field client-field-full">
                        <label asp-for="Input.Morada" class="client-label"></label>
                        <input asp-for="Input.Morada" class="client-input" />
                        <span asp-validation-for="Input.Morada" class="text-danger"></span>
                    </div>
                </div>

                <div class="client-form-actions">
                    <button class="auth-button" type="submit">
                        <i class="fa-solid fa-floppy-disk"></i>
                        <span>Guardar alterações</span>
                    </button>

                    <a asp-page="./Index" class="auth-button auth-button-secondary">
                        <i class="fa-solid fa-arrow-left"></i>
                        <span>Voltar</span>
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @* 
        Ativa a validação do lado do cliente com jQuery validation,
        caso o projeto já tenha o partial configurado.
    *@
    <partial name="_ValidationScriptsPartial" />
}
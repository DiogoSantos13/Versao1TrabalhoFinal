@page
@model Versao1TrabalhoFinal.Pages.PainelEmpresa.IndexModel
@{
    ViewData["Title"] = "Painel da Empresa";
}

@functions {
    public string GetEstadoClass(string? estado)
    {
        if (string.IsNullOrWhiteSpace(estado))
            return "status-neutral";

        return estado.Trim().ToLower() switch
        {
            "concluído" => "status-success",
            "entregue" => "status-success",
            "aprovado" => "status-success",
            "rejeitado" => "status-danger",
            "aguarda peças" => "status-warning",
            "em análise" => "status-warning",
            "em diagnóstico" => "status-warning",
            "em reparação" => "status-info",
            "pendente" => "status-neutral",
            _ => "status-neutral"
        };
    }
}

<section class="dashboard-page">
    <div class="dashboard-container">

        <div class="page-header-block">
            <div>
                <p class="page-eyebrow">Centro Operacional</p>
                <h1 class="page-title">Painel de trabalho da empresa</h1>
                <p class="page-subtitle">
                    Área interna para acompanhar ordens de reparação, produtos associados,
                    orçamentos, histórico de vendas e carrinhos dos clientes.
                </p>
            </div>

            <div class="page-header-side">
                <div class="page-header-chip">
                    Atualização em tempo real da operação interna
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="painel-alert painel-alert-success mb-4" role="alert">
                <div class="painel-alert-icon">✓</div>
                <div>
                    <strong>Operação concluída</strong>
                    <p class="mb-0">@TempData["SuccessMessage"]</p>
                </div>
            </div>
        }

        @if (!ViewContext.ModelState.IsValid && ViewContext.ModelState.ErrorCount > 0)
        {
            <div class="painel-alert painel-alert-danger mb-4" role="alert">
                <div class="painel-alert-icon">!</div>
                <div>
                    <strong>Foram encontrados erros</strong>
                    <div asp-validation-summary="All" class="text-danger mt-2"></div>
                </div>
            </div>
        }

        <div class="painel-kpi-grid">
            <div class="painel-kpi-card">
                <span class="painel-kpi-label">Total de vendas</span>
                <strong class="painel-kpi-value">@Model.Painel.TotalVendas.ToString("C")</strong>
                <small class="painel-kpi-helper">Valor acumulado registado</small>
            </div>

            <div class="painel-kpi-card">
                <span class="painel-kpi-label">Vendas finalizadas</span>
                <strong class="painel-kpi-value">@Model.Painel.TotalVendasFinalizadas</strong>
                <small class="painel-kpi-helper">Total de registos de venda</small>
            </div>

            <div class="painel-kpi-card">
                <span class="painel-kpi-label">Orçamentos pendentes</span>
                <strong class="painel-kpi-value">@Model.Painel.TotalOrcamentosPendentes</strong>
                <small class="painel-kpi-helper">Aguardam análise</small>
            </div>

            <div class="painel-kpi-card">
                <span class="painel-kpi-label">Ordens em aberto</span>
                <strong class="painel-kpi-value">@Model.Painel.TotalOrdensAbertas</strong>
                <small class="painel-kpi-helper">Ainda não concluídas</small>
            </div>
        </div>

        <div class="painel-section-card">
            <div class="painel-section-header">
                <div>
                    <h2>Ordens de reparação</h2>
                    <p>Gestão dos trabalhos de oficina em curso, com atualização de estado, responsável e custos.</p>
                </div>
                <span class="painel-section-counter">
                    @(Model.Painel.OrdensReparacao?.Count ?? 0) registos
                </span>
            </div>

            @if (Model.Painel.OrdensReparacao != null && Model.Painel.OrdensReparacao.Any())
            {
                foreach (var ordem in Model.Painel.OrdensReparacao)
                {
                    <div class="painel-subcard mb-4">
                        <div class="painel-subcard-header">
                            <div>
                                <h3 class="painel-subcard-title">Ordem #@ordem.Id</h3>
                                <p class="painel-subcard-subtitle">
                                    @ordem.ClienteNome · @ordem.VeiculoDescricao
                                </p>
                            </div>
                            <div class="painel-subcard-status">
                                <span class="status-badge @GetEstadoClass(ordem.Estado)">@ordem.Estado</span>
                            </div>
                        </div>

                        <div class="painel-ordem-grid">
                            <div class="painel-ordem-info">
                                <div class="painel-metric-grid">
                                    <div class="painel-metric-box">
                                        <span class="painel-metric-label">Cliente</span>
                                        <strong>@ordem.ClienteNome</strong>
                                    </div>
                                    <div class="painel-metric-box">
                                        <span class="painel-metric-label">Veículo</span>
                                        <strong>@ordem.VeiculoDescricao</strong>
                                    </div>
                                    <div class="painel-metric-box">
                                        <span class="painel-metric-label">Mecânico</span>
                                        <strong>@ordem.MecanicoResponsavel</strong>
                                    </div>
                                    <div class="painel-metric-box">
                                        <span class="painel-metric-label">Entrada</span>
                                        <strong>@ordem.DataEntrada.ToString("dd/MM/yyyy")</strong>
                                    </div>
                                    <div class="painel-metric-box">
                                        <span class="painel-metric-label">Mão de obra</span>
                                        <strong>@ordem.MaoDeObra.ToString("C")</strong>
                                    </div>
                                    <div class="painel-metric-box">
                                        <span class="painel-metric-label">Peças</span>
                                        <strong>@ordem.Pecas.ToString("C")</strong>
                                    </div>
                                    <div class="painel-metric-box painel-metric-box-highlight">
                                        <span class="painel-metric-label">Total</span>
                                        <strong>@ordem.Total.ToString("C")</strong>
                                    </div>
                                </div>

                                <div class="painel-note-box mt-3">
                                    <span class="painel-note-label">Serviços pedidos / descrição</span>
                                    <p class="mb-0">@ordem.ServicosPedidos</p>
                                </div>
                            </div>

                            <div class="painel-ordem-form">
                                <form method="post" asp-page-handler="AtualizarOrdem" class="painel-inline-form">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden"
                                           name="atualizacaoOrdem.OrdemReparacaoId"
                                           value="@ordem.Id" />

                                    <div class="painel-form-group">
                                        <label class="painel-label">Colaborador responsável</label>
                                        <select name="atualizacaoOrdem.ColaboradorId" class="painel-select">
                                            <option value="">Selecionar colaborador</option>
                                            @foreach (var colaborador in Model.ColaboradoresDisponiveis)
                                            {
                                                if (ordem.ColaboradorId.HasValue && colaborador.Value == ordem.ColaboradorId.Value.ToString())
                                                {
                                                    <option value="@colaborador.Value" selected>@colaborador.Text</option>
                                                }
                                                else
                                                {
                                                    <option value="@colaborador.Value">@colaborador.Text</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="painel-form-group">
                                        <label class="painel-label">Estado</label>
                                        <select name="atualizacaoOrdem.NovoEstado" class="painel-select">
                                            @foreach (var estado in Model.EstadosOrdem)
                                            {
                                                if (estado.Value == ordem.Estado)
                                                {
                                                    <option value="@estado.Value" selected>@estado.Text</option>
                                                }
                                                else
                                                {
                                                    <option value="@estado.Value">@estado.Text</option>
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="painel-form-row">
                                        <div class="painel-form-group">
                                            <label class="painel-label">Mão de obra</label>
                                            <input name="atualizacaoOrdem.MaoDeObra"
                                                   class="painel-input"
                                                   type="text"
                                                   inputmode="decimal"
                                                   value="@ordem.MaoDeObra.ToString("0.00")"
                                                   placeholder="0,00" />
                                        </div>

                                        <div class="painel-form-group">
                                            <label class="painel-label">Peças</label>
                                            <input name="atualizacaoOrdem.Pecas"
                                                   class="painel-input"
                                                   type="text"
                                                   inputmode="decimal"
                                                   value="@ordem.Pecas.ToString("0.00")"
                                                   placeholder="0,00" />
                                        </div>
                                    </div>

                                    <div class="painel-form-group">
                                        <label class="painel-label">Observações internas</label>
                                        <textarea name="atualizacaoOrdem.Observacoes"
                                          class="painel-textarea"
                                          rows="4"
                                          placeholder="Observações internas"></textarea>
                                    </div>

                                    <small class="painel-helper-text">
                                        Total atual registado: @ordem.Total.ToString("C")
                                    </small>

                                    <button type="submit" class="painel-btn painel-btn-primary">
                                        Guardar alterações da ordem
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="painel-inner-section mt-4">
                            <div class="painel-section-header small">
                                <div>
                                    <h4>Produtos associados à ordem</h4>
                                    <p>Peças e produtos usados nesta reparação.</p>
                                </div>
                            </div>

                            <div class="painel-table-wrapper">
                                <table class="painel-table">
                                    <thead>
                                        <tr>
                                            <th>Produto</th>
                                            <th>Quantidade</th>
                                            <th>Preço</th>
                                            <th>Subtotal</th>
                                            <th>Ação</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (ordem.Produtos != null && ordem.Produtos.Any())
                                        {
                                            foreach (var itemProduto in ordem.Produtos)
                                            {
                                                <tr>
                                                    <td>@itemProduto.ProdutoNome</td>
                                                    <td>@itemProduto.Quantidade</td>
                                                    <td>@itemProduto.Preco.ToString("C")</td>
                                                    <td>@itemProduto.Subtotal.ToString("C")</td>
                                                    <td>
                                                        <form method="post"
                                                              asp-page-handler="EliminarProdutoOrdem"
                                                              class="painel-inline-form"
                                                              onsubmit="return confirm('Tens a certeza que queres remover este produto da ordem?');">
                                                            @Html.AntiForgeryToken()

                                                            <input type="hidden" name="input.OrdemProdutoId" value="@itemProduto.Id" />
                                                            <input type="hidden" name="input.OrdemId" value="@ordem.Id" />

                                                            <button type="submit" class="painel-btn painel-btn-danger painel-btn-sm">
                                                                Eliminar
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5">Ainda não existem produtos associados a esta ordem.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="painel-add-item-box mt-3">
                                <h5>Adicionar produto à ordem</h5>

                                <form method="post" asp-page-handler="AdicionarProdutoOrdem" class="painel-inline-form">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="input.OrdemId" value="@ordem.Id" />

                                    <div class="painel-form-row">
                                        <div class="painel-form-group flex-grow-1">
                                            <label class="painel-label">Produto</label>
                                            <select name="input.ProdutoId" class="painel-select">
                                                <option value="">Selecionar produto</option>
                                                @if (Model.ProdutosDisponiveis != null && Model.ProdutosDisponiveis.Any())
                                                {
                                                    foreach (var produtoDisponivel in Model.ProdutosDisponiveis)
                                                    {
                                                        <option value="@produtoDisponivel.Value">@produtoDisponivel.Text</option>
                                                    }
                                                }
                                            </select>
                                        </div>

                                        <div class="painel-form-group">
                                            <label class="painel-label">Quantidade</label>
                                            <input name="input.Quantidade"
                                                   class="painel-input"
                                                   type="number"
                                                   min="1"
                                                   step="1"
                                                   value="1" />
                                        </div>
                                    </div>

                                    <button type="submit" class="painel-btn painel-btn-primary painel-btn-sm">
                                        Adicionar produto
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state-panel">
                    Não existem ordens de reparação registadas.
                </div>
            }
        </div>

        <div class="painel-section-card">
            <div class="painel-section-header">
                <div>
                    <h2>Orçamentos</h2>
                    <p>Consulta e atualização do estado, valor estimado e observações internas.</p>
                </div>
                <span class="painel-section-counter">
                    @(Model.Painel.Orcamentos?.Count ?? 0) registos
                </span>
            </div>

            <div class="painel-table-wrapper">
                <table class="painel-table painel-table-expanded">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Veículo</th>
                            <th>Descrição</th>
                            <th>Estado</th>
                            <th>Valor estimado</th>
                            <th>Data</th>
                            <th>Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Painel.Orcamentos != null && Model.Painel.Orcamentos.Any())
                        {
                            foreach (var orcamento in Model.Painel.Orcamentos)
                            {
                                <tr>
                                    <td>#@orcamento.Id</td>
                                    <td>@orcamento.ClienteNome</td>
                                    <td>@orcamento.VeiculoDescricao</td>
                                    <td>@orcamento.Descricao</td>
                                    <td>
                                        <span class="status-badge @GetEstadoClass(orcamento.Estado)">
                                            @orcamento.Estado
                                        </span>
                                    </td>
                                    <td>@(orcamento.ValorEstimado.HasValue? orcamento.ValorEstimado.Value.ToString("C") : "—")</td>
                                    <td>@(orcamento.DataCriacao.HasValue? orcamento.DataCriacao.Value.ToString("dd/MM/yyyy") : "—")</td>
                                    <td>
                                        <form method="post" asp-page-handler="AtualizarOrcamento" class="painel-inline-form painel-form-compact">
                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="atualizacaoOrcamento.OrcamentoId"
                                                   value="@orcamento.Id" />

                                            <label class="painel-label">Estado</label>
                                            <select name="atualizacaoOrcamento.NovoEstado" class="painel-select">
                                                @foreach (var estado in Model.EstadosOrcamento)
                                                {
                                                    if (estado.Value == orcamento.Estado)
                                                    {
                                                        <option value="@estado.Value" selected>@estado.Text</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@estado.Value">@estado.Text</option>
                                                    }
                                                }
                                            </select>

                                            <label class="painel-label">Valor estimado</label>
                                            <input name="atualizacaoOrcamento.ValorEstimado"
                                                   class="painel-input"
                                                   type="text"
                                                   inputmode="decimal"
                                                   value="@(orcamento.ValorEstimado.HasValue? orcamento.ValorEstimado.Value.ToString("0.00") : "")"
                                                   placeholder="0,00" />

                                            <label class="painel-label">Descrição adicional / observações</label>
                                            <textarea name="atualizacaoOrcamento.DescricaoAdicional"
                                              class="painel-textarea"
                                              rows="3"
                                              placeholder="Descrição adicional / observações internas">@orcamento.Descricao</textarea>

                                            <button type="submit" class="painel-btn painel-btn-primary painel-btn-sm">
                                                Guardar orçamento
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8">Não existem orçamentos registados.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="painel-section-card">
            <div class="painel-section-header">
                <div>
                    <h2>Histórico de vendas</h2>
                    <p>Resumo dos registos de venda existentes.</p>
                </div>
                <span class="painel-section-counter">
                    @(Model.Painel.Vendas?.Count ?? 0) registos
                </span>
            </div>

            <div class="painel-table-wrapper">
                <table class="painel-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Cliente</th>
                            <th>Data</th>
                            <th>Tipo</th>
                            <th>Itens</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Painel.Vendas != null && Model.Painel.Vendas.Any())
                        {
                            foreach (var venda in Model.Painel.Vendas)
                            {
                                <tr>
                                    <td>#@venda.Id</td>
                                    <td>@venda.ClienteNome</td>
                                    <td>@venda.DataVenda.ToString("dd/MM/yyyy")</td>
                                    <td>@venda.Tipo</td>
                                    <td>@venda.ItensResumo</td>
                                    <td>@venda.Total.ToString("C")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6">Não existem vendas registadas.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="painel-section-card">
            <div class="painel-section-header">
                <div>
                    <h2>Carrinhos dos clientes</h2>
                    <p>Consulta interna dos carrinhos ativos e respetivos produtos, serviços e veículos do stand.</p>
                </div>
                <span class="painel-section-counter">
                    @(Model.Painel.Carrinhos?.Count ?? 0) registos
                </span>
            </div>

            @if (Model.Painel.Carrinhos != null && Model.Painel.Carrinhos.Any())
            {
                foreach (var carrinho in Model.Painel.Carrinhos)
                {
                    <div class="painel-subcard mb-4">
                        <div class="painel-subcard-header">
                            <div>
                                <h3 class="painel-subcard-title">Carrinho #@carrinho.Id</h3>
                                <p class="painel-subcard-subtitle">
                                    Cliente: @carrinho.ClienteNome · Criado em @carrinho.DataCriacao.ToString("dd/MM/yyyy HH:mm")
                                </p>
                            </div>
                        </div>

                        <div class="painel-inner-section mt-3">
                            <h4 class="painel-mini-title">Produtos</h4>
                            <div class="painel-table-wrapper">
                                <table class="painel-table">
                                    <thead>
                                        <tr>
                                            <th>Produto</th>
                                            <th>Quantidade</th>
                                            <th>Preço no momento</th>
                                            <th>Data de adição</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (carrinho.Produtos != null && carrinho.Produtos.Any())
                                        {
                                            foreach (var produtoCarrinho in carrinho.Produtos)
                                            {
                                                <tr>
                                                    <td>@produtoCarrinho.NomeProduto</td>
                                                    <td>@produtoCarrinho.Quantidade</td>
                                                    <td>@produtoCarrinho.PrecoNoMomento.ToString("C")</td>
                                                    <td>@produtoCarrinho.DataAdicao.ToString("dd/MM/yyyy HH:mm")</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="4">Sem produtos neste carrinho.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="painel-inner-section mt-3">
                            <h4 class="painel-mini-title">Serviços</h4>
                            <div class="painel-table-wrapper">
                                <table class="painel-table">
                                    <thead>
                                        <tr>
                                            <th>Serviço</th>
                                            <th>Preço no momento</th>
                                            <th>Data de adição</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (carrinho.Servicos != null && carrinho.Servicos.Any())
                                        {
                                            foreach (var servicoCarrinho in carrinho.Servicos)
                                            {
                                                <tr>
                                                    <td>@servicoCarrinho.NomeServico</td>
                                                    <td>@servicoCarrinho.PrecoNoMomento.ToString("C")</td>
                                                    <td>@servicoCarrinho.DataAdicao.ToString("dd/MM/yyyy HH:mm")</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="3">Sem serviços neste carrinho.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="painel-inner-section mt-3">
                            <h4 class="painel-mini-title">Veículos do stand</h4>
                            <div class="painel-table-wrapper">
                                <table class="painel-table">
                                    <thead>
                                        <tr>
                                            <th>Veículo</th>
                                            <th>Preço no momento</th>
                                            <th>Data de adição</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (carrinho.Veiculos != null && carrinho.Veiculos.Any())
                                        {
                                            foreach (var veiculoCarrinho in carrinho.Veiculos)
                                            {
                                                <tr>
                                                    <td>@veiculoCarrinho.VeiculoDescricao</td>
                                                    <td>@veiculoCarrinho.PrecoNoMomento.ToString("C")</td>
                                                    <td>@veiculoCarrinho.DataAdicao.ToString("dd/MM/yyyy HH:mm")</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="3">Sem veículos do stand neste carrinho.</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state-panel">
                    Não existem carrinhos de clientes para mostrar.
                </div>
            }
        </div>

    </div>
</section>

<style>
    .dashboard-page {
        padding: 2rem 0 4rem;
        background:
            radial-gradient(circle at top right, rgba(15, 118, 110, 0.08), transparent 24rem),
            linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        min-height: 100vh;
    }

    .dashboard-container {
        width: min(1400px, 94%);
        margin: 0 auto;
    }

    .page-header-block {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 2rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
        padding: 2rem;
        border-radius: 1.25rem;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
        color: #fff;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.18);
    }

    .page-eyebrow {
        margin: 0 0 0.5rem;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: rgba(255,255,255,0.72);
    }

    .page-title {
        margin: 0;
        font-size: clamp(2rem, 3vw, 3rem);
        font-weight: 800;

@page
@model Versao1TrabalhoFinal.Pages.VeiculosStand.IndexModel
@{
    ViewData["Title"] = "Veículos do Stand";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="list-header">
            <div>
                <p class="page-eyebrow">Stand automóvel</p>
                <h1 class="page-title">Veículos disponíveis</h1>
                <p class="page-subtitle">Explore o stock atualmente disponível no stand.</p>
            </div>

            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
            {
                <a asp-page="/VeiculosStand/Create" class="auth-button list-header-button">
                    Novo veículo do stand
                </a>
            }
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="success-banner">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="error-banner">
                @TempData["ErrorMessage"]
            </div>
        }

        @if (Model.VeiculosStand != null && Model.VeiculosStand.Any())
        {
            <div class="vehicle-grid">
                @foreach (var item in Model.VeiculosStand)
                {
                    var imagemPrincipal = item.Imagens?
                    .OrderByDescending(i => i.Principal)
                    .ThenBy(i => i.Ordem)
                    .FirstOrDefault();

                    var imagem = imagemPrincipal != null
                    ? imagemPrincipal.Url
                    : Url.Content("~/images/cars/default-car.jpg");

                    <div class="vehicle-admin-card">
                        <div class="vehicle-admin-image-wrap">
                            <img src="@imagem"
                                 class="vehicle-admin-image"
                                 alt="@(item.Veiculo?.Marca ?? "Veículo") @(item.Veiculo?.Modelo ?? "")"
                                 onerror="this.onerror=null;this.src='@Url.Content("~/images/cars/default-car.jpg")';" />
                        </div>

                        <div class="vehicle-admin-body">
                            <h3 class="vehicle-admin-title">
                                @(item.Veiculo?.Marca ?? "Marca") @(item.Veiculo?.Modelo ?? "Modelo")
                            </h3>

                            <p class="vehicle-admin-status">
                                @(string.IsNullOrWhiteSpace(item.Estado) ? "Disponível" : item.Estado)
                            </p>

                            <div class="vehicle-admin-meta">
                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Preço</span>
                                    <strong>€ @item.Preco.ToString("N2")</strong>
                                </div>

                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Quilómetros</span>
                                    <strong>@item.Quilometros.ToString("N0")</strong>
                                </div>
                            </div>

                            <div class="vehicle-admin-meta">
                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Ano</span>
                                    <strong>@(item.Veiculo?.Ano)</strong>
                                </div>

                                <div class="vehicle-admin-meta-item">
                                    <span class="vehicle-admin-meta-label">Combustível</span>
                                    <strong>@(string.IsNullOrWhiteSpace(item.Veiculo?.Combustivel) ? "-" : item.Veiculo?.Combustivel)</strong>
                                </div>
                            </div>

                            <div class="vehicle-admin-actions">
                                <a asp-page="/VeiculosStand/Details"
                                   asp-route-id="@item.Id"
                                   class="action-link action-link-primary">
                                    Ver detalhes
                                </a>

                                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                                {
                                    <a asp-page="/VeiculosStand/Edit"
                                       asp-route-id="@item.Id"
                                       class="action-link action-link-primary">
                                        Editar
                                    </a>

                                    <a asp-page="/VeiculosStand/Delete"
                                       asp-route-id="@item.Id"
                                       class="action-link action-link-danger">
                                        Eliminar
                                    </a>
                                }
                                else
                                {
                                    if (User.Identity != null && User.Identity.IsAuthenticated)
                                    {
                                        <a asp-page="/Carrinho/Adicionar"
                                           asp-route-veiculoStandId="@item.Id"
                                           class="action-link action-link-primary">
                                            Adicionar ao carrinho
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-page="/Account/Login"
                                           asp-route-returnUrl="@Url.Page("/VeiculosStand/Index")"
                                           class="action-link action-link-primary">
                                            Iniciar sessão
                                        </a>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state-card">
                <h3>Sem veículos em stock</h3>
                <p>Não existem viaturas disponíveis para mostrar neste momento.</p>

                @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <a asp-page="/VeiculosStand/Create" class="auth-button">
                        Adicionar veículo ao stand
                    </a>
                }
            </div>
        }
    </div>
</section>
@page
@model Versao1TrabalhoFinal.Pages.ClienteArea.VeiculosModel
@{
    ViewData["Title"] = "Meus Veículos";
}

<h2 class="mb-4">Os meus veículos</h2>

<div class="row g-4">
    @foreach (var veiculo in Model.Veiculos)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card h-100 shadow-sm">
                <img src="@veiculo.ImagemUrl" class="card-img-top" style="height:220px; object-fit:cover;" alt="@veiculo.Marca @veiculo.Modelo" />
                <div class="card-body">
                    <h5>@veiculo.Marca @veiculo.Modelo</h5>
                    <p class="text-muted">@veiculo.Matricula</p>
                    <p>Ano: @veiculo.Ano</p>
                    <p>Combustível: @veiculo.Combustivel</p>
                    <p>Cor: @veiculo.Cor</p>
                </div>
            </div>
        </div>
    }
</div>

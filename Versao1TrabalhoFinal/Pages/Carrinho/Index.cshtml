@page
@model Versao1TrabalhoFinal.Pages.Carrinho.IndexModel
@{
    ViewData["Title"] = "Carrinho";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="page-header-block">
            <p class="page-eyebrow">Cliente</p>
            <h1 class="page-title">Carrinho</h1>
            <p class="page-subtitle">Consulta os serviços e produtos atualmente associados ao teu carrinho.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-3">@TempData["SuccessMessage"]</div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger mb-3">@TempData["ErrorMessage"]</div>
        }

        <div class="client-form-card mb-4">
            <h2 class="section-title mb-3">Serviços</h2>

            @if (Model.ItensServicos != null && Model.ItensServicos.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Serviço</th>
                                <th>Preço</th>
                                <th>Data</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ItensServicos)
                            {
                                <tr>
                                    <td>@item.Servico?.Nome</td>
                                    <td>@item.PrecoNoMomento.ToString("0.00 €")</td>
                                    <td>@item.DataAdicao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <a asp-page="/Carrinho/Remover"
                                           asp-page-handler="Servico"
                                           asp-route-id="@item.Id"
                                           class="auth-button auth-button-secondary">
                                            Remover
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Ainda não tens serviços no carrinho.</p>
            }
        </div>

        <div class="client-form-card mb-4">
            <h2 class="section-title mb-3">Produtos</h2>

            @if (Model.ItensProdutos != null && Model.ItensProdutos.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th>Preço</th>
                                <th>Quantidade</th>
                                <th>Subtotal</th>
                                <th>Data</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ItensProdutos)
                            {
                                <tr>
                                    <td>@item.Produto?.Nome</td>
                                    <td>@item.PrecoNoMomento.ToString("0.00 €")</td>
                                    <td>@item.Quantidade</td>
                                    <td>@((item.PrecoNoMomento * item.Quantidade).ToString("0.00 €"))</td>
                                    <td>@item.DataAdicao.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end">
                                        <a asp-page="/Carrinho/Remover"
                                           asp-page-handler="Produto"
                                           asp-route-id="@item.Id"
                                           class="auth-button auth-button-secondary">
                                            Remover
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Ainda não tens produtos no carrinho.</p>
            }
        </div>

        <div class="client-summary-card">
            <h3 class="client-summary-name">Resumo</h3>
            <p class="client-summary-email mb-2">Total atual do carrinho</p>
            <h2>@Model.Total.ToString("0.00 €")</h2>

            <div class="client-form-actions mt-4">
                <a asp-page="/Produtos/Index" class="auth-button auth-button-secondary">
                    <i class="fa-solid fa-box-open"></i>
                    <span>Continuar compras</span>
                </a>

                <a asp-page="/Carrinho/Checkout" class="auth-button">
                    <i class="fa-solid fa-credit-card"></i>
                    <span>Checkout</span>
                </a>
            </div>
        </div>
    </div>
</section>
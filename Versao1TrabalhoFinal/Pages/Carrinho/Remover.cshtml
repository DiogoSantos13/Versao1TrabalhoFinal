@page
@model Versao1TrabalhoFinal.Pages.Carrinho.RemoverModel
@{
    ViewData["Title"] = "Remover Item";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="page-header-block">
            <p class="page-eyebrow">Carrinho</p>
            <h1 class="page-title">Remover item</h1>
            <p class="page-subtitle">Escolhe uma ação para voltar ao carrinho ou continuar a navegar.</p>
        </div>

        <div class="client-form-card">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success mb-3">@TempData["SuccessMessage"]</div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger mb-3">@TempData["ErrorMessage"]</div>
            }

            <div class="client-form-actions">
                <a asp-page="/Carrinho/Index" class="auth-button">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Voltar ao carrinho</span>
                </a>

                <a asp-page="/Produtos/Index" class="auth-button auth-button-secondary">
                    <i class="fa-solid fa-box-open"></i>
                    <span>Continuar compras</span>
                </a>
            </div>
        </div>
    </div>
</section>
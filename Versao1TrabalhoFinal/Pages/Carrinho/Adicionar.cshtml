@page
@model Versao1TrabalhoFinal.Pages.Carrinho.AdicionarModel
@{
    ViewData["Title"] = "Adicionar Veículo";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="page-header-block">
            <p class="page-eyebrow">Carrinho</p>
            <h1 class="page-title">Adicionar veículo</h1>
            <p class="page-subtitle">Neste momento o carrinho está configurado apenas para produtos e serviços.</p>
        </div>

        <div class="client-form-card">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger mb-3">@TempData["ErrorMessage"]</div>
            }

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success mb-3">@TempData["SuccessMessage"]</div>
            }

            <p class="text-muted mb-4">
                Se quiseres guardar veículos no carrinho, precisas de criar uma entidade própria para isso.
            </p>

            <div class="client-form-actions">
                <a asp-page="/VeiculosStand/Index" class="auth-button auth-button-secondary">
                    <i class="fa-solid fa-arrow-left"></i>
                    <span>Voltar ao stand</span>
                </a>

                <a asp-page="/Carrinho/Index" class="auth-button">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Ir para o carrinho</span>
                </a>
            </div>
        </div>
    </div>
</section>
@page
@model Versao1TrabalhoFinal.Pages.Carrinho.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="page-header-block">
            <p class="page-eyebrow">Checkout</p>
            <h1 class="page-title">Resumo final</h1>
            <p class="page-subtitle">Confirma os itens do carrinho antes de avançar.</p>
        </div>

        <div class="client-form-card mb-4">
            <h2 class="section-title mb-3">Serviços</h2>

            @if (Model.Servicos != null && Model.Servicos.Any())
            {
                <ul class="list-group">
                    @foreach (var item in Model.Servicos)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@item.Servico?.Nome</span>
                            <strong>@item.PrecoNoMomento.ToString("0.00 €")</strong>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted mb-0">Sem serviços no checkout.</p>
            }
        </div>

        <div class="client-form-card mb-4">
            <h2 class="section-title mb-3">Produtos</h2>

            @if (Model.Produtos != null && Model.Produtos.Any())
            {
                <ul class="list-group">
                    @foreach (var item in Model.Produtos)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@item.Produto?.Nome x @item.Quantidade</span>
                            <strong>@((item.PrecoNoMomento * item.Quantidade).ToString("0.00 €"))</strong>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted mb-0">Sem produtos no checkout.</p>
            }
        </div>

        <div class="client-summary-card">
            <h3 class="client-summary-name">Total a pagar</h3>
            <h2 class="mb-3">@Model.Total.ToString("0.00 €")</h2>

            <div class="client-form-actions">
                <a asp-page="/Carrinho/Index" class="auth-button auth-button-secondary">
                    <i class="fa-solid fa-arrow-left"></i>
                    <span>Voltar ao carrinho</span>
                </a>

                <button type="button" class="auth-button">
                    <i class="fa-solid fa-check"></i>
                    <span>Confirmar pedido</span>
                </button>
            </div>
        </div>
    </div>
</section>
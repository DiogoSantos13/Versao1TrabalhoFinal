@page
@model Versao1TrabalhoFinal.Pages.Carrinho.AdicionarServicoModel
@{
    ViewData["Title"] = "Adicionar Serviço";
}

<section class="dashboard-page">
    <div class="dashboard-container">
        <div class="page-header-block">
            <p class="page-eyebrow">Carrinho</p>
            <h1 class="page-title">Adicionar serviço</h1>
            <p class="page-subtitle">O serviço selecionado será associado ao teu carrinho.</p>
        </div>

        <div class="client-form-card">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger mb-3">@TempData["ErrorMessage"]</div>
            }

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success mb-3">@TempData["SuccessMessage"]</div>
            }

            <p class="text-muted mb-4">
                Se esta página apareceu diretamente, regressa à listagem de serviços para escolher um serviço.
            </p>

            <div class="client-form-actions">
                <a asp-page="/Servicos/Index" class="auth-button auth-button-secondary">
                    <i class="fa-solid fa-screwdriver-wrench"></i>
                    <span>Ver serviços</span>
                </a>

                <a asp-page="/Carrinho/Index" class="auth-button">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>Ver carrinho</span>
                </a>
            </div>
        </div>
    </div>
</section>